DJANGO_SECRET_KEY=replace-with-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000

DB_ENGINE=django.db.backends.postgresql
DB_NAME=inventory
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432

AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-east-1

RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=support@example.com

STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_PRICE_ID_MONTHLY=replace-with-monthly-price-id
STRIPE_PRICE_ID_QUARTERLY=replace-with-quarterly-price-id
STRIPE_PRICE_ID_ANNUAL=replace-with-annual-price-id
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
